--additional
-m64
-Wno-comment
-Wno-deprecated-declarations
-Wno-expansion-to-defined
-Wno-extern-c-compat
-Wno-extern-initializer
-Wno-extra-tokens
-Wno-ignored-attributes
-Wno-ignored-pragma-intrinsic
-Wno-macro-redefined
-Wno-nonportable-include-path
-Wno-pragma-pack
-Wno-switch
--config
codegen=preview
file=multi
vtbls=trimmable
--generate
aggressive-inlining
callconv-member-function
com-proxies=false
cpp-attributes
disable-runtime-marshalling
doc-includes
empty-records=false
enum-operators=false
file-scoped-namespaces
generic-pointer-wrapper
guid-member
macro-bindings
marker-interfaces
native-inheritance-attribute
setslastsystemerror-attribute
tests-nunit
unmanaged-constants
vtbl-index-attribute
--log
potential-typedef-remappings
--define-macro
GDIPVER=0x0110
INITGUID
UNICODE
--header-file
header.txt
--include-directory
../../../include
../../../include/d3d12
../../../include/d3d12on7
../../../include/d3dx12
../../../include/dxtk12
C:/Program Files (x86)/Windows Kits/10/Include/10.0.28000.0/shared
C:/Program Files (x86)/Windows Kits/10/Include/10.0.28000.0/ucrt
C:/Program Files (x86)/Windows Kits/10/Include/10.0.28000.0/um
C:/Program Files (x86)/Windows Kits/10/Include/10.0.28000.0/winrt
--with-callconv
*=Winapi
